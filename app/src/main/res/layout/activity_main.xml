<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Gaze Overlay (full screen) -->
    <com.eyetracker.app.ui.GazeOverlayView
        android:id="@+id/gazeOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Status Bar -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1A1F35"
        android:padding="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/cameraPreview"
        app:layout_constraintStart_toStartOf="parent">

        <View
            android:id="@+id/statusIndicator"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/circle_red" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Camera ready"
            android:textColor="#B0BEC5"
            android:textSize="13sp"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/tvBlink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="#FFC107" />
    </LinearLayout>

    <!-- Stats Grid -->
    <GridLayout
        android:id="@+id/statsGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:background="#111827"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintStart_toStartOf="parent">

        <TextView android:id="@+id/tvGazeX" android:text="X: --" android:textColor="#64B5F6"
            android:textSize="11sp" android:padding="6dp" android:fontFamily="monospace"/>
        <TextView android:id="@+id/tvGazeY" android:text="Y: --" android:textColor="#64B5F6"
            android:textSize="11sp" android:padding="6dp" android:fontFamily="monospace"/>
        <TextView android:id="@+id/tvConfidence" android:text="Conf: --" android:textColor="#A5D6A7"
            android:textSize="11sp" android:padding="6dp" android:fontFamily="monospace"/>
        <TextView android:id="@+id/tvYaw" android:text="Yaw: --" android:textColor="#CE93D8"
            android:textSize="11sp" android:padding="6dp" android:fontFamily="monospace"/>
        <TextView android:id="@+id/tvPitch" android:text="Pitch: --" android:textColor="#CE93D8"
            android:textSize="11sp" android:padding="6dp" android:fontFamily="monospace"/>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/tvLeftEye" android:text="L: --" android:textColor="#FFCC80"
                android:textSize="11sp" android:padding="6dp" android:fontFamily="monospace"/>
            <TextView android:id="@+id/tvRightEye" android:text="R: --" android:textColor="#FFCC80"
                android:textSize="11sp" android:padding="6dp" android:fontFamily="monospace"/>
        </LinearLayout>
    </GridLayout>

    <!-- Controls -->
    <LinearLayout
        android:id="@+id/controlsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/statsGrid"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Toggle switches -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView android:text="Heatmap" android:textColor="#B0BEC5"
                android:layout_width="0dp" android:layout_weight="1" android:textSize="14sp"/>
            <Switch android:id="@+id/switchHeatmap" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:checked="false" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <TextView android:text="Gaze Trail" android:textColor="#B0BEC5"
                android:layout_width="0dp" android:layout_weight="1" android:textSize="14sp"/>
            <Switch android:id="@+id/switchTrail" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:checked="true" />
        </LinearLayout>

        <!-- Main buttons -->
        <Button
            android:id="@+id/btnStartStop"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Start Tracking"
            android:textColor="#FFFFFF"
            android:backgroundTint="@color/start_color"
            android:layout_marginBottom="8dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="8dp">
            <Button
                android:id="@+id/btnCalibrate"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="Calibrate"
                android:textSize="13sp"
                android:backgroundTint="#1A2744"
                android:layout_marginEnd="4dp" />
            <Button
                android:id="@+id/btnClearHeatmap"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="Clear Map"
                android:textSize="13sp"
                android:backgroundTint="#1A2744"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnDemo"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="🎮 Gaze Demo"
            android:backgroundTint="#0D2137"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnOverlay"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Enable Global Overlay"
            android:backgroundTint="#1A0D37" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
