<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A">

    <View
        android:id="@+id/demoCanvas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#1A1F35" />

    <com.eyetracker.app.ui.GazeOverlayView
        android:id="@+id/gazeOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ProgressBar
        android:id="@+id/dwellProgress"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="200dp"
        android:layout_height="8dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="24dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#4FC3F7" />

    <TextView
        android:id="@+id/blinkIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="24dp"
        android:text="BLINK"
        android:textColor="#FFC107"
        android:textSize="16sp"
        android:visibility="invisible" />

    <LinearLayout
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="40dp">

        <Button android:id="@+id/demoBtn1" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="Red"
            android:backgroundTint="#1A2744" android:layout_marginBottom="8dp" />
        <Button android:id="@+id/demoBtn2" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="Green"
            android:backgroundTint="#1A2744" android:layout_marginBottom="8dp" />
        <Button android:id="@+id/demoBtn3" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="Blue"
            android:backgroundTint="#1A2744" android:layout_marginBottom="8dp" />
        <Button android:id="@+id/demoBtn4" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="Yellow"
            android:backgroundTint="#1A2744" android:layout_marginBottom="8dp" />
        <Button android:id="@+id/demoBtn5" android:layout_width="match_parent"
            android:layout_height="52dp" android:text="Purple"
            android:backgroundTint="#1A2744" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvDemoFeedback"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="120dp"
        android:text="Look at a button for 1.5s to select"
        android:textColor="#78909C"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="40dp"
        android:text="Back"
        android:backgroundTint="#1A2744" />

</FrameLayout>
